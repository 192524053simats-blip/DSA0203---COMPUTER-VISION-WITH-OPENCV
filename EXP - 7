import cv2
import time
from google.colab.patches import cv2_imshow

video_path = "V_992.mp4"

cap = cv2.VideoCapture(video_path)

if not cap.isOpened():
    print("Cannot open video.")
else:
    print("----- SLOW MOTION -----")

    while True:
        ret, frame = cap.read()

        if not ret:
            break

        cv2_imshow(frame)
        time.sleep(0.10)

    cap.release()

cap = cv2.VideoCapture(video_path)

print("----- FAST MOTION -----")

while True:
    ret, frame = cap.read()

    if not ret:
        break

    cv2_imshow(frame)

    # Skip alternate frames
    cap.read()

cap.release()

print("Experiment Completed Successfully")
